{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "paths": {
      "@open-agent/*": ["./packages/*/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
